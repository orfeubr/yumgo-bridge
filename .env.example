APP_NAME=YumGo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Sao_Paulo

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Asaas Payment Gateway (Legado)
ASAAS_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_PLATFORM_WALLET_ID=
ASAAS_WEBHOOK_TOKEN=

# Pagar.me Payment Gateway (Principal)
PAGARME_URL=https://api.pagar.me/core/v5
PAGARME_API_KEY=
PAGARME_ENCRYPTION_KEY=
PAGARME_PLATFORM_RECIPIENT_ID=
PAGARME_WEBHOOK_TOKEN=

# Tributa AI - Classificação Fiscal com IA
# Token da PLATAFORMA (compartilhado entre TODOS os restaurantes)
# Restaurantes podem ter token próprio apenas em planos Enterprise
TRIBUTAAI_PLATFORM_TOKEN=

# OAuth Social Login (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Social Login (Facebook)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# WhatsApp Verification API (escolher uma)
# Opção 1: Twilio (pago, confiável) - https://www.twilio.com/pt-br/messaging/whatsapp
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=

# Opção 2: Evolution API (gratuito, self-hosted) - https://github.com/EvolutionAPI/evolution-api
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=

# Opção 3: Maytapi (freemium) - https://maytapi.com/
MAYTAPI_PRODUCT_ID=
MAYTAPI_API_KEY=
MAYTAPI_PHONE_ID=

VITE_APP_NAME="${APP_NAME}"
